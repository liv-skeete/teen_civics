# ============================================================================
# TeenCivics Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Congress.gov API Configuration
# ----------------------------------------------------------------------------
# Get your API key from: https://api.congress.gov/sign-up/
# The Congress.gov API provides access to legislative data including bills,
# amendments, and congressional records.
# Rate limit: 5,000 requests per hour
CONGRESS_API_KEY=your_congress_gov_api_key_here

# ----------------------------------------------------------------------------
# Anthropic (Claude) API Configuration
# ----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
# Used for AI-powered bill summarization to create plain-English explanations
# Rate limits vary by plan (see: https://docs.anthropic.com/claude/reference/rate-limits)
ANTHROPIC_API_KEY=your_claude_api_key_here

# ----------------------------------------------------------------------------
# Twitter / X API Configuration
# ----------------------------------------------------------------------------
# Get your credentials from: https://developer.twitter.com/en/portal/dashboard
# You'll need to create a Twitter Developer account and an app with read/write permissions
#
# Required for posting tweets:
# - API Key (also called Consumer Key)
# - API Secret (also called Consumer Secret)
# - Access Token
# - Access Token Secret
# - Bearer Token (for API v2 endpoints)
#
# Rate limits vary by tier:
# - Free: Limited posting capabilities
# - Basic: ~1,500 tweets per month
# - Pro: Higher limits
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Optional OAuth 2.0 credentials (not currently used but available for future features)
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string (REQUIRED for production)
# Get from your database provider (e.g., Supabase, Heroku, AWS RDS)
#
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://myuser:mypassword@db.example.com:5432/teencivics
#
# For Supabase:
# 1. Go to Project Settings > Database
# 2. Copy the "Connection string" under "Connection pooling"
# 3. Replace [YOUR-PASSWORD] with your actual database password
#
# For local development, you can use SQLite (not recommended for production):
# DATABASE_URL=sqlite:///data/bills.db
DATABASE_URL=postgresql://user:password@host:port/database

# ----------------------------------------------------------------------------
# Flask Application Configuration (Optional)
# ----------------------------------------------------------------------------
# These settings control the Flask web application behavior

# Enable debug mode (shows detailed error pages, auto-reloads on code changes)
# WARNING: Never enable debug mode in production!
# FLASK_DEBUG=False

# Port for the web application (default: 5000)
# PORT=5000

# Host address (default: 0.0.0.0 to accept connections from any IP)
# Use 127.0.0.1 for localhost-only access
# FLASK_HOST=0.0.0.0

# ----------------------------------------------------------------------------
# Logging Configuration (Optional)
# ----------------------------------------------------------------------------
# Control logging verbosity and format

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Log format (Python logging format string)
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ----------------------------------------------------------------------------
# GitHub Actions Secrets
# ----------------------------------------------------------------------------
# When deploying with GitHub Actions, add these as repository secrets:
# 1. Go to your repository on GitHub
# 2. Settings > Secrets and variables > Actions
# 3. Add each variable as a "New repository secret"
#
# Required secrets for GitHub Actions:
# - CONGRESS_API_KEY
# - ANTHROPIC_API_KEY
# - TWITTER_API_KEY
# - TWITTER_API_SECRET
# - TWITTER_BEARER_TOKEN
# - TWITTER_ACCESS_TOKEN
# - TWITTER_ACCESS_SECRET
# - DATABASE_URL