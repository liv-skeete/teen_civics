# .env.example
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# API Keys
VENICE_API_KEY=your_venice_api_key
CONGRESS_API_KEY=your_congress_api_key

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your_secret_key

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Argument Generation Models (Venice AI)
# Available models: claude-opus-4-6, claude-sonnet-4-6, kimi-k2-5, llama-3.3-70b, hermes-3-llama-3.1-405b
ARGUMENT_MODEL=claude-opus-4-6
ARGUMENT_FALLBACK=kimi-k2-5
